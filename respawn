-- ============================================================================
-- ULTIMATE RESPAWN SCRIPT - EVENT DRIVEN & UI STRIPPED
-- ============================================================================
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer

-- Global State for Future UI Integration
_G.RespawnConfig = _G.RespawnConfig or { Active = true }

-- Force engine settings for minimum latency
pcall(function()
    Players.RespawnTime = 0
    settings().Physics.ThrottleAdjustTime = 0
    settings().Physics.IsReceiveAgeOfReplication = false
end)

-- Cache respawn remotes once instead of searching every death
local RespawnRemotes = {}
local function cacheRespawnMethods()
    table.clear(RespawnRemotes)
    local function search(parent)
        for _, v in ipairs(parent:GetDescendants()) do
            if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then
                local n = v.Name:lower()
                if n:find("respawn") or n:find("reset") or n:find("spawn") or n:find("death") or n:find("guide") then
                    table.insert(RespawnRemotes, v)
                end
            end
        end
    end
    pcall(search, ReplicatedStorage)
    pcall(search, LocalPlayer)
end
cacheRespawnMethods()

-- Instant Server Sync & Collision Bypass
local function instantServerSync(char)
    pcall(function()
        if char then
            local head = char:FindFirstChild("Head")
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if head then head.CanCollide = false end
            if hrp then hrp.CanCollide = false end
        end
    end)
end

-- Physics Reset & Ragdoll Prevention
local function optimizeCharacter(char)
    task.spawn(function()
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.Velocity = Vector3.zero
            hrp.RotVelocity = Vector3.zero
        end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then hum.PlatformStand = false end
        for _, p in ipairs(char:GetDescendants()) do
            if p:IsA("BasePart") then
                p.Velocity = Vector3.zero
                p.RotVelocity = Vector3.zero
            elseif p:IsA("Motor6D") or p:IsA("Weld") then
                p.Enabled = true
            end
        end
    end)
end

-- Instant Respawn Trigger
local function triggerInstantRespawn()
    if not _G.RespawnConfig.Active then return end
    
    -- Fire all cached remotes in parallel
    task.spawn(function()
        for _, remote in ipairs(RespawnRemotes) do
            pcall(function()
                if remote:IsA("RemoteEvent") then remote:FireServer()
                elseif remote:IsA("RemoteFunction") then remote:InvokeServer() end
            end)
        end
    end)
    
    -- Direct character nil to force engine respawn
    task.delay(0.02, function()
        pcall(function() LocalPlayer.Character = nil end)
    end)
end

-- EVENT DRIVEN: Monitor Death via Humanoid.Died instead of Heartbeat polling
local function onCharacterAdded(character)
    if not _G.RespawnConfig.Active then return end
    
    optimizeCharacter(character)
    instantServerSync(character)
    
    local humanoid = character:WaitForChild("Humanoid", 5)
    if humanoid then
        humanoid.Died:Connect(triggerInstantRespawn)
    end
end

-- Manual Respawn Keybind (R)
game:GetService("UserInputService").InputBegan:Connect(function(input, gpe)
    if gpe or not _G.RespawnConfig.Active then return end
    if input.KeyCode == Enum.KeyCode.R and LocalPlayer.Character then
        triggerInstantRespawn()
    end
end)

LocalPlayer.CharacterAdded:Connect(onCharacterAdded)
if LocalPlayer.Character then onCharacterAdded(LocalPlayer.Character) end

print("✅ [UPGRADED] Respawn Script Loaded - Event Driven, No UI")