-- ============================================================================
-- LOOP BRING - POSTSIMULATION SMOOTH & UI STRIPPED
-- ============================================================================
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

-- Global State for Future UI Integration
_G.LoopBringConfig = _G.LoopBringConfig or { 
    Active = true,
    Targets = {}, -- Dictionary: [UserId] = true
    Offset = CFrame.new(0, 0, -3)
}

-- PostSimulation for smoothest possible bring (every physics tick)
RunService.PostSimulation:Connect(function()
    if not _G.LoopBringConfig.Active then return end
    
    local myChar = LocalPlayer.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end
    
    for userId, _ in pairs(_G.LoopBringConfig.Targets) do
        local player = Players:GetPlayerByUserId(userId)
        if player and player.Character then
            local targetHRP = player.Character:FindFirstChild("HumanoidRootPart")
            if targetHRP then
                -- Direct CFrame assignment (no tweening overhead)
                targetHRP.CFrame = myHRP.CFrame * _G.LoopBringConfig.Offset
                targetHRP.Velocity = Vector3.zero
                targetHRP.RotVelocity = Vector3.zero
            end
        end
    end
end)

-- Helper API for future UI integration
_G.LoopBringAPI = {
    AddTarget = function(player)
        if player and player.UserId then
            _G.LoopBringConfig.Targets[player.UserId] = true
        end
    end,
    RemoveTarget = function(player)
        if player and player.UserId then
            _G.LoopBringConfig.Targets[player.UserId] = nil
        end
    end,
    ClearAll = function()
        table.clear(_G.LoopBringConfig.Targets)
    end,
    Toggle = function(state)
        _G.LoopBringConfig.Active = state
    end
}

print("✅ [UPGRADED] LoopBring Loaded - PostSimulation Smooth, No UI")