-- Smooth Open/Close Toggle logic
local isOpened = false
local function toggleVisibility()
    isOpened = not isOpened
    local targetSize = isOpened and UDim2.new(0, 240, 0, 280) or UDim2.new(0, 240, 0, 0)
    
    if isOpened then Frame.Visible = true end
    
    local tween = TweenService:Create(Frame, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = targetSize})
    tween:Play()
    
    tween.Completed:Connect(function()
        if not isOpened then Frame.Visible = false end
    end)
end
ToggleButton.MouseButton1Click:Connect(toggleVisibility)

-- Main Loopbring functionality
local function loopBring(targetPlayer, label)
    if LoopBrings[targetPlayer.UserId] then
        LoopBrings[targetPlayer.UserId] = nil
        label.Text = targetPlayer.Name
        tweenColor(label, "TextColor3", COLORS.TextInActive)
        return
    end

    LoopBrings[targetPlayer.UserId] = true
    label.Text = "🔥 " .. targetPlayer.Name .. " [Bring]"
    tweenColor(label, "TextColor3", COLORS.TextActive)

    task.spawn(function()
        while LoopBrings[targetPlayer.UserId] and targetPlayer and targetPlayer.Character do
            if not Players:FindFirstChild(targetPlayer.Name) then break end
            
            -- Wait for LocalPlayer to respawn if they're dead
            while not LocalPlayer.Character do
                task.wait(0.1)
            end
            
            local targetHRP = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
            local localHRP = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            
            if targetHRP and localHRP then
                targetHRP.CFrame = localHRP.CFrame * CFrame.new(0, 0, -3)
                targetHRP.Velocity = Vector3.new(0, 0, 0)
            end
            task.wait(0.1)
        end
    end)
end

-- Refresh List UI
local function updatePlayerList()
    for _, child in ipairs(ListFrame:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end

    local playerCount = 0
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            playerCount = playerCount + 1
            
            local playerButton = Instance.new("TextButton")
            playerButton.Size = UDim2.new(1, 0, 0, 36)
            playerButton.BackgroundColor3 = COLORS.CardBg
            playerButton.Text = player.Name
            playerButton.TextColor3 = COLORS.TextInActive
            playerButton.Font = Enum.Font.GothamMedium
            playerButton.TextSize = 13
            playerButton.AutoButtonColor = false
            playerButton.Parent = ListFrame

            local BtnCorner = Instance.new("UICorner", playerButton)
            BtnCorner.CornerRadius = UDim.new(0, 6)
            
            local BtnStroke = Instance.new("UIStroke", playerButton)
            BtnStroke.Color = Color3.fromRGB(45, 30, 32)
            BtnStroke.Thickness = 1

            if LoopBrings[player.UserId] then
                playerButton.Text = "🔥 " .. player.Name .. " [Bring]"
                playerButton.TextColor3 = COLORS.TextActive
            end

            -- Interactive Hover Effects
            playerButton.MouseEnter:Connect(function()
                tweenColor(playerButton, "BackgroundColor3", COLORS.HoverBg)
                tweenColor(BtnStroke, "Color", COLORS.Accent)
            end)
            playerButton.MouseLeave:Connect(function()
                tweenColor(playerButton, "BackgroundColor3", COLORS.CardBg)
                tweenColor(BtnStroke, "Color", Color3.fromRGB(45, 30, 32))
            end)

            playerButton.MouseButton1Click:Connect(function()
                loopBring(player, playerButton)
            end)
        end
    end
    ListFrame.CanvasSize = UDim2.new(0, 0, 0, playerCount * 42)
end

-- Dynamic Listeners
Players.PlayerAdded:Connect(function(player)
    updatePlayerList()
    if LoopBrings[player.UserId] then
        task.wait(1)
        for _, button in ipairs(ListFrame:GetChildren()) do
            if button:IsA("TextButton") and button.Text:find(player.Name) then
                loopBring(player, button)
            end
        end
    end
end)

Players.PlayerRemoving:Connect(updatePlayerList)
updatePlayerList()
