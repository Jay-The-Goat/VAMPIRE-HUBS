-- ============================================================================
-- ULTIMATE USE TOOLS - EVENT DRIVEN AUTO-ACTIVATE & PHYSICS NOCLIP
-- ============================================================================
local Players = game:GetService("Players")
local PhysicsService = game:GetService("PhysicsService")
local LocalPlayer = Players.LocalPlayer

-- Global State for Future UI Integration
_G.UseToolsConfig = _G.UseToolsConfig or { Active = true, Noclip = true }

-- Setup Noclip Collision Group (Server-Synced, Zero Overhead)
pcall(function()
    PhysicsService:RegisterCollisionGroup("AutoNoclip")
    PhysicsService:CollisionGroupSetCollidable("AutoNoclip", "Default", false)
end)

local trackedTools = {}

-- Apply noclip group to all character parts
local function applyNoclip(char)
    if not _G.UseToolsConfig.Noclip then return end
    pcall(function()
        for _, p in ipairs(char:GetDescendants()) do
            if p:IsA("BasePart") then
                p.CollisionGroup = "AutoNoclip"
                p.CanCollide = false
            end
        end
    end)
end

-- Instant Equip + Activate Pipeline
local function processTool(tool)
    if not _G.UseToolsConfig.Active or not tool:IsA("Tool") then return end
    if trackedTools[tool] then return end
    trackedTools[tool] = true
    
    -- Instant equip
    pcall(function() tool.Parent = LocalPlayer.Character end)
    
    -- Activate on equip event (guaranteed ready state)
    local conn
    conn = tool.Equipped:Connect(function()
        pcall(function() tool:Activate() end)
        conn:Disconnect()
    end)
    
    -- Fallback activate after minimal delay
    task.delay(0.01, function()
        if tool.Parent == LocalPlayer.Character then
            pcall(function() tool:Activate() end)
        end
    end)
end

-- EVENT DRIVEN: Backpack Monitoring (Zero Polling)
LocalPlayer.Backpack.ChildAdded:Connect(processTool)

-- Character Added: Apply noclip + process existing tools
LocalPlayer.CharacterAdded:Connect(function(char)
    table.clear(trackedTools)
    applyNoclip(char)
    
    -- Process tools already in backpack
    for _, tool in ipairs(LocalPlayer.Backpack:GetChildren()) do
        processTool(tool)
    end
    
    -- Monitor new descendants for noclip
    char.DescendantAdded:Connect(function(desc)
        if _G.UseToolsConfig.Noclip and desc:IsA("BasePart") then
            pcall(function()
                desc.CollisionGroup = "AutoNoclip"
                desc.CanCollide = false
            end)
        end
    end)
end)

-- Continuous Activation for Held Tools (Event-Based Alternative to Loop)
-- Uses Tool.Activated signal re-trigger pattern instead of Stepped loop
local function setupContinuousActivation()
    LocalPlayer.CharacterAdded:Connect(function(char)
        char.ChildAdded:Connect(function(child)
            if child:IsA("Tool") and _G.UseToolsConfig.Active then
                child.Activated:Connect(function()
                    -- Re-activate for continuous effect tools
                    task.delay(0.05, function()
                        if child.Parent == char and _G.UseToolsConfig.Active then
                            pcall(function() child:Activate() end)
                        end
                    end)
                end)
            end
        end)
    end)
end
setupContinuousActivation()

if LocalPlayer.Character then applyNoclip(LocalPlayer.Character) end

print("✅ [UPGRADED] Use Tools Loaded - Event Driven, PhysicsService Noclip, No UI")