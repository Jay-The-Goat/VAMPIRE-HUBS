-- ============================
-- 👥 Player Button Factory
-- ============================

local function createPlayerButton(plr)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, -12, 0, 26)
	btn.Text = plr.Name
	btn.Font = Enum.Font.Gotham
	btn.TextSize = 13
	btn.AutoButtonColor = false

	btn.BackgroundColor3 = Color3.fromRGB(12, 12, 16)
	btn.TextColor3 = Color3.fromRGB(215, 225, 255)

	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10)

	local stroke = Instance.new("UIStroke", btn)
	stroke.Thickness = 1
	stroke.Color = Color3.fromRGB(90, 120, 255)
	stroke.Transparency = 0.45

	btn.MouseButton1Click:Connect(function()
		local list = getgenv().configs.TargetList
		local idx = table.find(list, plr)

		if idx then
			table.remove(list, idx)
			btn.BackgroundColor3 = Color3.fromRGB(12, 12, 16)
			stroke.Color = Color3.fromRGB(90, 120, 255)
		else
			table.insert(list, plr)
			btn.BackgroundColor3 = Color3.fromRGB(20, 25, 45)
			stroke.Color = Color3.fromRGB(90, 150, 255)
		end
	end)

	return btn
end

local function UpdatePlayers()
	for _, c in ipairs(PlayerFrame:GetChildren()) do
		if c:IsA("TextButton") then
			c:Destroy()
		end
	end

	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= lp then
			createPlayerButton(p).Parent = PlayerFrame
		end
	end
end

-- Toggle panel
AuraBtn.MouseButton1Click:Connect(function()
	PlayerFrame.Visible = not PlayerFrame.Visible
	if PlayerFrame.Visible then
		UpdatePlayers()
	end
end)

Players.PlayerAdded:Connect(UpdatePlayers)
Players.PlayerRemoving:Connect(UpdatePlayers)

-- ============================
-- ⚔️ Aura Logic (unchanged)
-- ============================

table.insert(getgenv().configs.connections,
	RunService.Heartbeat:Connect(function()
		if not Run then return end
		if #getgenv().configs.TargetList == 0 then return end

		local char = getchar()
		if not char then return end

		local chars = GetCharacters()
		Ignorelist.FilterDescendantsInstances = chars

		for _, tool in ipairs(char:GetChildren()) do
			if tool:IsA("Tool") then
				local touch = GetTouchInterest(tool)
				if touch then
					ApplyDamageInstant(tool, touch)
				end
			end
		end
	end)
)

table.insert(getgenv().configs.connections,
	RunService.RenderStepped:Connect(function()
		if not Run then return end
		if #getgenv().configs.TargetList == 0 then return end

		local char = getchar()
		if not char then return end

		local best
		for _, plr in ipairs(getgenv().configs.TargetList) do
			if plr.Character and plr.Character:FindFirstChild("Humanoid") then
				local hum = plr.Character.Humanoid
				if hum.Health > 0 then
					if not best or hum.Health < best.Humanoid.Health then
						best = { Humanoid = hum, Char = plr.Character }
					end
				end
			end
		end

		if not best then return end

		for _, tool in ipairs(char:GetChildren()) do
			if tool:IsA("Tool") then
				local touch = GetTouchInterest(tool)
				if touch then
					for _, part in ipairs(best.Char:GetChildren()) do
						if part:IsA("BasePart") then
							firetouchinterest(touch, part, 1)
							firetouchinterest(touch, part, 0)
						end
					end
				end
			end
		end
	end)
)
