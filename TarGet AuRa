-- ============================================================================
-- TARGET AURA - EVENT DRIVEN & UI STRIPPED
-- ============================================================================
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local lp = Players.LocalPlayer

-- Global State for Future UI Integration
_G.TargetAuraConfig = _G.TargetAuraConfig or { 
    Active = true, 
    Size = Vector3.new(30, 30, 30),
    TargetList = {} -- Populate from future UI
}

local Ignorelist = OverlapParams.new()
Ignorelist.FilterType = Enum.RaycastFilterType.Include

local function getTouchPart(tool)
    for _, obj in ipairs(tool:GetDescendants()) do
        if obj:IsA("TouchTransmitter") and obj.Parent:IsA("BasePart") then
            return obj.Parent
        end
    end
    return nil
end

local function attackTargets(touchPart)
    if not touchPart or #_G.TargetAuraConfig.TargetList == 0 then return end
    
    -- Build include list from target characters
    local chars = {}
    for _, plr in ipairs(_G.TargetAuraConfig.TargetList) do
        if plr and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            table.insert(chars, plr.Character)
        end
    end
    
    if #chars == 0 then return end
    Ignorelist.FilterDescendantsInstances = chars
    
    local parts = workspace:GetPartBoundsInBox(
        touchPart.CFrame,
        touchPart.Size + _G.TargetAuraConfig.Size,
        Ignorelist
    )
    
    for _, p in ipairs(parts) do
        pcall(firetouchinterest, touchPart, p, 0)
        pcall(firetouchinterest, touchPart, p, 1)
    end
end

-- PostSimulation: Fastest safe execution point (replaces Heartbeat + RenderStepped)
RunService.PostSimulation:Connect(function()
    if not _G.TargetAuraConfig.Active then return end
    local char = lp.Character
    if not char then return end
    
    for _, tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") then
            local touch = getTouchPart(tool)
            if touch then attackTargets(touch) end
        end
    end
end)

print("✅ [UPGRADED] Target Aura Loaded - PostSimulation, No UI")