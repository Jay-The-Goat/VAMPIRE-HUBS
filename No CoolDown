-- ============================================================================
-- 7. MULTI-LEVEL DEBOUNCE CLEANER - ALL VALUE TYPES
-- ============================================================================
local function multiLevelDebounceClean()
    task.spawn(function()
        while true do
            if scriptActive then
                pcall(function()
                    for _, player in pairs(Players:GetPlayers()) do
                        if player.Character then
                            for _, obj in pairs(player.Character:GetDescendants()) do
                                -- Clean IntValue, NumberValue, BoolValue
                                if obj:IsA("IntValue") or obj:IsA("NumberValue") or obj:IsA("BoolValue") then
                                    local name = obj.Name:lower()
                                    if name:find("cool") or name:find("debounce") or name:find("last") or name:find("time") or name:find("delay") or name:find("wait") then
                                        if obj:IsA("IntValue") or obj:IsA("NumberValue") then
                                            obj.Value = 0
                                        elseif obj:IsA("BoolValue") then
                                            obj.Value = false
                                        end
                                    end
                                end
                            end
                        end
                    end
                end)
            end
            renderStepped:Wait()
        end
    end)
end

