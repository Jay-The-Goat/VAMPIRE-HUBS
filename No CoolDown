-- ============================================================================
-- 2. HOOK SPAWN - INSTANT EXECUTION
-- ============================================================================
local originalSpawn = task.spawn
task.spawn = function(func, ...)
    if not scriptActive then
        return originalSpawn(func, ...)
    end
    local args = {...}
    originalSpawn(function()
        func(unpack(args))
    end)
end

-- ============================================================================
-- 3. HOOK DELAY - REMOVE DELAYS COMPLETELY
-- ============================================================================
local hookDelay = hookfunction(delay, function(duration, callback, ...)
    if not scriptActive then
        return originalDelay(duration, callback, ...)
    end
    if callback then
        callback(...)
    end
    return nil
end)

-- ============================================================================
-- 4. HOOK TASK.WAIT - ULTRA-FAST EXECUTION
-- ============================================================================
local originalTaskWait = task.wait
task.wait = function(duration)
    if not scriptActive then
        return originalTaskWait(duration)
    end
    if duration and duration > 0 then
        renderStepped:Wait()
    end
    return os.clock()
end

