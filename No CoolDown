-- 11. NETWORK LAG REDUCER - REMOVE SERVER DELAYS
-- ============================================================================
local function networkLagReducer()
    task.spawn(function()
        while true do
            if scriptActive then
                pcall(function()
                    if LocalPlayer and LocalPlayer.Character then
                        -- Optimize network sync
                        for _, part in pairs(LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and {LocalPlayer.Character.HumanoidRootPart} or {}) do
