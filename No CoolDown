-- 8. TOOL COOLDOWN BYPASS - INSTANT TOOL ACTIVATION
-- ============================================================================
local function toolCooldownBypass()
    task.spawn(function()
        while true do
            if scriptActive and LocalPlayer and LocalPlayer.Character then
                pcall(function()
                    for _, tool in pairs(LocalPlayer.Character:GetChildren()) do
                        if tool:IsA("Tool") then
                            -- Find and zero all tool cooldowns
                            for _, desc in pairs(tool:GetDescendants()) do
                                if desc:IsA("IntValue") or desc:IsA("NumberValue") then
                                    if desc.Name:lower():find("cool") or desc.Name:lower():find("debounce") then
                                        desc.Value = 0
                                    end
                                end
                            end
                        end
                    end
                end)
            end
            renderStepped:Wait()
        end
    end)
end

