-- Cache service and signal for maximum execution speed
local RunService = game:GetService("RunService")
local Stepped = RunService.Stepped

-- Cache the original wait to prevent infinite loops during hooking
local oldWait = wait

-- Hook the global wait function exactly how you intended
hookfunction(wait, function(duration)
    -- Sync perfectly with the game's physics simulation frame
    Stepped:Wait() 
    
    -- Return 0 to prevent external scripts from crashing on nil values
    return 0
end)
