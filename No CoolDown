-- Optimize service indexing
local task = task
local getgenv = getgenv or function() return _G end

-- Cache core task functions for maximum execution speed
local task_wait = task.wait
local task_defer = task.defer

-- Safely modify the environment
local success, err = pcall(function()
    -- 1. Upgrade global wait to instant execution via task.defer
    getgenv().wait = function(duration)
        task_defer(coroutine.running())
        return 0, 0
    end

    -- 2. Hook task.wait if exploit environment allows hookfunction
    if hookfunction then
        hookfunction(task.wait, function(duration)
            task_defer(coroutine.running())
            return 0, 0
        end)
    end
end)

if not success then
    warn("Failed to apply no-cooldown patch: " .. tostring(err))
end
