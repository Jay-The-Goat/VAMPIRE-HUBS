-- ============================================================================
-- ULTIMATE TOOL COLLECTOR - EVENT DRIVEN & PROXIMITY PROMPT OPTIMIZED
-- ============================================================================
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Tycoons = workspace:WaitForChild("Tycoons")

-- Global State for Future UI Integration
_G.ToolCollectorConfig = _G.ToolCollectorConfig or { Active = true }

local excludedBases = { Insanity=true, Giant=true, Dark=true, Spike=true, Web=true, Strong=true }
local ValidGivers = {}
local CachedPrompts = {}

-- Cache valid gear givers and their proximity prompts
local function cacheGivers()
    table.clear(ValidGivers)
    table.clear(CachedPrompts)
    
    for _, descendant in ipairs(Tycoons:GetDescendants()) do
        if descendant:IsA("TouchTransmitter") then
            local part = descendant.Parent
            local giver = part and part.Parent
            if giver and giver.Name:find("GearGiver") then
                local base = giver.Parent
                if base and not excludedBases[base.Name] then
                    table.insert(ValidGivers, part)
                    -- Cache any ProximityPrompts for instant trigger
                    local prompt = giver:FindFirstChildWhichIsA("ProximityPrompt", true)
                    if prompt then table.insert(CachedPrompts, prompt) end
                end
            end
        end
    end
end

-- Instant Collection: Trigger Prompts + Simulate Touch
local function turboCollect()
    if not _G.ToolCollectorConfig.Active then return end
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    -- Priority 1: Instant ProximityPrompt Trigger (Fastest Method)
    for _, prompt in ipairs(CachedPrompts) do
        pcall(function() prompt:Trigger(LocalPlayer) end)
    end
    
    -- Priority 2: Direct CFrame overlap for TouchTransmitters
    for _, part in ipairs(ValidGivers) do
        pcall(function()
            firetouchinterest(root, part, 0)
            firetouchinterest(root, part, 1)
        end)
    end
end

-- Event: Collect on Respawn
LocalPlayer.CharacterAdded:Connect(function(char)
    if not _G.ToolCollectorConfig.Active then return end
    task.defer(function()
        cacheGivers()
        -- Burst collect on spawn
        for _ = 1, 3 do turboCollect() end
    end)
end)

-- Event: Dynamic Giver Detection
Tycoons.DescendantAdded:Connect(function(desc)
    if _G.ToolCollectorConfig.Active and desc:IsA("TouchTransmitter") then
        cacheGivers()
        turboCollect()
    end
end)

-- Initial Setup
cacheGivers()
if LocalPlayer.Character then turboCollect() end

print("✅ [UPGRADED] Tool Collector Loaded - Event Driven, No UI")