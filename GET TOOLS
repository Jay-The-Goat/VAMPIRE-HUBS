-- Toggle Logic Function
local function UpdateUIState()
    if _G.ScriptEnabled then
        ToggleButton.Text = "COLLECTOR: ON"
        ToggleButton.TextColor3 = Color3.fromRGB(255, 0, 0) -- Bright Red
        UIStroke.Color = Color3.fromRGB(255, 0, 0) -- Bright Red Border
    else
        ToggleButton.Text = "COLLECTOR: OFF"
        ToggleButton.TextColor3 = Color3.fromRGB(130, 0, 0) -- Dimmed Dark Red
        UIStroke.Color = Color3.fromRGB(80, 0, 0) -- Dimmed Border
    end
end

ToggleButton.MouseButton1Click:Connect(function()
    _G.ScriptEnabled = not _G.ScriptEnabled
    UpdateUIState()
end)

-- ============================================================================
-- MAIN CORE LOGIC
-- ============================================================================
local excludedBases = { "Insanity", "Giant", "Dark", "Spike", "Web", "Strong" }
local allowedBases = { "Stone", "Magic", "Storm", "Robotic" }

local allowedBasesSet = {}
for _, base in ipairs(allowedBases) do allowedBasesSet[base] = true end

local function IsValidBase(baseName)
    if not baseName then return false end
    return allowedBasesSet[baseName] or not table.find(excludedBases, baseName)
end

local ValidGivers = {}
local GiverCount = 0

local function CacheGivers()
    if not _G.ScriptEnabled then return end
    local temp = {}
    local count = 0
    local descendants = Tycoons:GetDescendants()
    
    for i = 1, #descendants do
        local v = descendants[i]
        if v:IsA("TouchTransmitter") then
            local part = v.Parent
            local parentGiver = part and part.Parent
            if parentGiver and parentGiver.Name:find("GearGiver1") then
                local baseParent = parentGiver.Parent
                if IsValidBase(baseParent and baseParent.Name) then
                    count = count + 1
                    temp[count] = part
                end
            end
        end
    end
    ValidGivers = temp
    GiverCount = count
end

local function TurboCollect()
    if not _G.ScriptEnabled then return end
    
    local Character = LocalPlayer.Character
    local Root = Character and Character:FindFirstChild("HumanoidRootPart")
    if not Root or GiverCount == 0 then return end

    local givers = ValidGivers
    for i = 1, GiverCount do
        local part = givers[i]
        firetouchinterest(Root, part, 0)
        firetouchinterest(Root, part, 1)
    end
end

local function OnRespawn(Character)
    if not _G.ScriptEnabled then return end
    
    local Root = Character:WaitForChild("HumanoidRootPart", 1)
    if not Root then return end
    
    CacheGivers()
    
    TurboCollect()
    TurboCollect()
    
    local t = os.clock()
    while os.clock() - t < 0.05 and _G.ScriptEnabled do
        TurboCollect()
    end
end

Tycoons.DescendantAdded:Connect(function(descendant)
    if _G.ScriptEnabled and descendant:IsA("TouchTransmitter") then
        CacheGivers()
        TurboCollect()
    end
end)

-- Dedicated thread running at absolute maximum yield speed limits
task.spawn(function()
    while true do
        if _G.ScriptEnabled then
            TurboCollect()
        end
        RunService.Heartbeat:Wait()
    end
end)

LocalPlayer.CharacterAdded:Connect(OnRespawn)

-- Initial run setup
CacheGivers()
if LocalPlayer.Character then
    task.spawn(OnRespawn, LocalPlayer.Character)
end