-- ============================================================================
-- MODULE 1: NO COOLDOWN (Hook-Based + Speed Slider)
-- ============================================================================
local originalWait = task.wait
local originalDelay = task.delay
local originalSpawn = task.spawn

local function applyNoCooldown(speedMult)
    local fastYield = function(t)
        return originalWait((t or 0) / math.max(speedMult, 1))
    end
    hookfunction(wait, fastYield)
    hookfunction(task.wait, fastYield)
    hookfunction(delay, function(t, func) originalSpawn(func) end)
    hookfunction(spawn, function(func) originalSpawn(func) end)
    hookfunction(task.defer, function(func) originalSpawn(func) end)
    hookfunction(task.delay, function(t, func) originalSpawn(func) end)
end

local function removeNoCooldown()
    hookfunction(wait, originalWait)
    hookfunction(task.wait, originalWait)
    -- Restore others if possible; fallback to safe defaults
    pcall(function() hookfunction(delay, delay) end)
    pcall(function() hookfunction(spawn, spawn) end)
end

-- ============================================================================
-- MODULE 2: RESPAWN (Event-Driven, No Heartbeat)
-- ============================================================================
pcall(function()
    Players.RespawnTime = 0
    settings().Physics.ThrottleAdjustTime = 0
    settings().Physics.IsReceiveAgeOfReplication = false
end)

local RespawnRemotes = {}
local function cacheRespawnMethods()
    table.clear(RespawnRemotes)
    local function search(parent)
        for _, v in ipairs(parent:GetDescendants()) do
            if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then
                local n = v.Name:lower()
                if n:find("respawn") or n:find("reset") or n:find("spawn") or n:find("death") or n:find("guide") then
                    table.insert(RespawnRemotes, v)
                end
            end
        end
    end
    pcall(search, ReplicatedStorage)
    pcall(search, LocalPlayer)
end
cacheRespawnMethods()

local function instantServerSync(char)
    pcall(function()
        if char then
            local h = char:FindFirstChild("Head")
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if h then h.CanCollide = false end
            if hrp then hrp.CanCollide = false end
        end
    end)
end

local function optimizeCharacter(char)
    task.spawn(function()
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.Velocity = Vector3.zero; hrp.RotVelocity = Vector3.zero end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then hum.PlatformStand = false end
        for _, p in ipairs(char:GetDescendants()) do
            if p:IsA("BasePart") then p.Velocity = Vector3.zero; p.RotVelocity = Vector3.zero
            elseif p:IsA("Motor6D") or p:IsA("Weld") then p.Enabled = true end
        end
    end)
end

local function triggerInstantRespawn()
    if not _G.VampireHub.Respawn.Active then return end
    if os.clock() - _G.VampireHub.Respawn.Buffer < 0.1 then return end
    _G.VampireHub.Respawn.Buffer = os.clock()
    instantServerSync(LocalPlayer.Character)
    task.spawn(function()
        for _, r in ipairs(RespawnRemotes) do
            pcall(function()
                if r:IsA("RemoteEvent") then r:FireServer()
                elseif r:IsA("RemoteFunction") then r:InvokeServer() end
            end)
        end
    end)
    task.delay(0.02, function() pcall(function() LocalPlayer.Character = nil end) end)
end

local respawnCharConn, respawnKeyConn
local function enableRespawn()
    cacheRespawnMethods()
    respawnCharConn = LocalPlayer.CharacterAdded:Connect(function(char)
        optimizeCharacter(char)
        instantServerSync(char)
        local hum = char:WaitForChild("Humanoid", 5)
        if hum then hum.Died:Connect(triggerInstantRespawn) end
    end)
    respawnKeyConn = UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe or input.KeyCode ~= Enum.KeyCode.R then return end
        if LocalPlayer.Character then triggerInstantRespawn() end
    end)
    if LocalPlayer.Character then
        local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum.Died:Connect(triggerInstantRespawn) end
    end
end

local function disableRespawn()
    if respawnCharConn then respawnCharConn:Disconnect(); respawnCharConn = nil end
    if respawnKeyConn then respawnKeyConn:Disconnect(); respawnKeyConn = nil end
end

