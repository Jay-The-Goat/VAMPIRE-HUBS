-- MODULE 4: USE TOOLS (Event-Driven + SPEED SLIDER + SOUND BREAKING)
-- ============================================================================
pcall(function()
    PhysicsService:RegisterCollisionGroup("VampireNoclip")
    PhysicsService:CollisionGroupSetCollidable("VampireNoclip", "Default", false)
end)

local useToolsBackpackConn, useToolsCharConn
local trackedTools = {}

local function applyNoclip(char)
    if not _G.VampireHub.UseTools.Noclip then return end
    pcall(function()
        for _, p in ipairs(char:GetDescendants()) do
            if p:IsA("BasePart") then p.CollisionGroup = "VampireNoclip"; p.CanCollide = false end
        end
    end)
end

local function processTool(tool)
    if not _G.VampireHub.UseTools.Active or not tool:IsA("Tool") then return end
    if trackedTools[tool] then return end
    trackedTools[tool] = true
    pcall(function() tool.Parent = LocalPlayer.Character end)
    local conn
    conn = tool.Equipped:Connect(function()
        pcall(function() tool:Activate() end)
        conn:Disconnect()
    end)
    task.delay(0.01, function()
        if tool.Parent == LocalPlayer.Character then pcall(function() tool:Activate() end) end
    end)
end

-- 🔊 SOUND-BREAKING ACTIVATION LOOP
-- At max speed (10), this fires ~600 activates/sec per tool
-- Overwhelms audio engine with simultaneous Activate() sounds
local useToolsLoopConn
local function startSoundBreakingLoop()
    if useToolsLoopConn then useToolsLoopConn:Disconnect() end
    useToolsLoopConn = RunService.PostSimulation:Connect(function()
        if not _G.VampireHub.UseTools.Active then return end
        local char = LocalPlayer.Character
        if not char then return end
        local speed = _G.VampireHub.UseTools.Speed
        -- Burst count scales with slider: 1=1 burst, 10=10 bursts per tick
        local bursts = math.clamp(math.floor(speed), 1, 10)
        for _, tool in ipairs(char:GetChildren()) do
            if tool:IsA("Tool") then
                for _ = 1, bursts do
                    pcall(function() tool:Activate() end)
                end
            end
        end
    end)
end

local function enableUseTools()
    table.clear(trackedTools)
    useToolsBackpackConn = LocalPlayer.Backpack.ChildAdded:Connect(processTool)
    useToolsCharConn = LocalPlayer.CharacterAdded:Connect(function(char)
        table.clear(trackedTools)
        applyNoclip(char)
        for _, t in ipairs(LocalPlayer.Backpack:GetChildren()) do processTool(t) end
        char.DescendantAdded:Connect(function(desc)
            if _G.VampireHub.UseTools.Noclip and desc:IsA("BasePart") then
                pcall(function() desc.CollisionGroup = "VampireNoclip"; desc.CanCollide = false end)
            end
        end)
    end)
    if LocalPlayer.Character then applyNoclip(LocalPlayer.Character) end
    startSoundBreakingLoop()
end

local function disableUseTools()
    if useToolsBackpackConn then useToolsBackpackConn:Disconnect(); useToolsBackpackConn = nil end
    if useToolsCharConn then useToolsCharConn:Disconnect(); useToolsCharConn = nil end
    if useToolsLoopConn then useToolsLoopConn:Disconnect(); useToolsLoopConn = nil end
    table.clear(trackedTools)
end

-- ============================================================================
-- MODULE 5: KILL AURA (PostSimulation Burst)
-- ============================================================================
local killAuraConn
local auraParams = OverlapParams.new()
auraParams.FilterType = Enum.RaycastFilterType.Include
local lastRemote = 0

local function enableKillAura()
    killAuraConn = RunService.PostSimulation:Connect(function()
        if not _G.VampireHub.KillAura.Active then return end
        local char = LocalPlayer.Character
        if not char then return end
        local myHRP = char:FindFirstChild("HumanoidRootPart")
        if not myHRP then return end
        local targets = {}
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then
                local c = p.Character
                local r = c and c:FindFirstChild("HumanoidRootPart")
                if r and (r.Position - myHRP.Position).Magnitude <= 35 then
                    table.insert(targets, c)
                end
            end
        end
        if #targets == 0 then return end
        auraParams.FilterDescendantsInstances = targets
        local now = os.clock()
        local fireRemote = (now - lastRemote) > 0.05
        for _, tool in ipairs(char:GetChildren()) do
            if tool:IsA("Tool") then
                if fireRemote then
                    local fe = tool:FindFirstChild("FightEvent")
                    if fe then task.spawn(function() pcall(function() fe:FireServer() end) end) end
                end
                local tp = tool:FindFirstChildWhichIsA("TouchTransmitter", true)
                tp = tp and tp.Parent
                if tp then
                    local parts = workspace:GetPartBoundsInBox(tp.CFrame, tp.Size + Vector3.new(35,35,35), auraParams)
                    for _, ep in ipairs(parts) do
                        for _ = 1, 3 do
                            pcall(firetouchinterest, tp, ep, 0)
                            pcall(firetouchinterest, tp, ep, 1)
                        end
                    end
                end
            end
        end
        if fireRemote then lastRemote = now end
    end)
end

local function disableKillAura()
    if killAuraConn then killAuraConn:Disconnect(); killAuraConn = nil end
end

