        local healthPercent = math.clamp(humanoid.Health / humanoid.MaxHealth, 0, 1)
        HealthBarFill.Size = UDim2.new(healthPercent, 0, 1, 0)
    end
    humanoid.HealthChanged:Connect(updateFill)
