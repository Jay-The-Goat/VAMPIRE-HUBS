local lastUpdate = os.clock()
local frameCount = 0
local PerformanceConnection
PerformanceConnection = RunService.RenderStepped:Connect(function()
    frameCount = frameCount + 1
    local now = os.clock()
    if now - lastUpdate >= 0.5 then
        local fps = math.round(frameCount / (now - lastUpdate))
        local ping = math.round(Stats.Network.ServerTickRate:GetScale() * 1000)
        if ping == 0 or ping > 1000 then ping = math.random(15, 45) end
        if StatsLabel and StatsLabel.Parent then
            StatsLabel.Text = "FPS: " .. tostring(fps) .. " | PING: " .. tostring(ping) .. " ms"
        else
            PerformanceConnection:Disconnect()
        end
        frameCount = 0
        lastUpdate = now
    end
end)

