-- MODULE 3: GET TOOLS (Event-Driven Collection)
-- ============================================================================
local Tycoons = workspace:FindFirstChild("Tycoons")
local ValidGivers = {}
local CachedPrompts = {}
local excludedBases = { Insanity=true, Giant=true, Dark=true, Spike=true, Web=true, Strong=true }

local function cacheGivers()
    table.clear(ValidGivers); table.clear(CachedPrompts)
    if not Tycoons then return end
    for _, desc in ipairs(Tycoons:GetDescendants()) do
        if desc:IsA("TouchTransmitter") then
            local part = desc.Parent
            local giver = part and part.Parent
            if giver and giver.Name:find("GearGiver") then
                local base = giver.Parent
                if base and not excludedBases[base.Name] then
                    table.insert(ValidGivers, part)
                    local prompt = giver:FindFirstChildWhichIsA("ProximityPrompt", true)
                    if prompt then table.insert(CachedPrompts, prompt) end
                end
            end
        end
    end
end

local function turboCollect()
    if not _G.VampireHub.GetTools.Active then return end
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    for _, prompt in ipairs(CachedPrompts) do pcall(function() prompt:Trigger(LocalPlayer) end) end
    for _, part in ipairs(ValidGivers) do
        pcall(firetouchinterest, root, part, 0)
        pcall(firetouchinterest, root, part, 1)
    end
end

local getToolsCharConn, getToolsDescConn
local function enableGetTools()
    cacheGivers()
    getToolsCharConn = LocalPlayer.CharacterAdded:Connect(function()
        task.defer(function() cacheGivers(); for _=1,3 do turboCollect() end end)
    end)
    getToolsDescConn = Tycoons and Tycoons.DescendantAdded:Connect(function(desc)
        if desc:IsA("TouchTransmitter") then cacheGivers(); turboCollect() end
    end)
    turboCollect()
end

local function disableGetTools()
    if getToolsCharConn then getToolsCharConn:Disconnect(); getToolsCharConn = nil end
    if getToolsDescConn then getToolsDescConn:Disconnect(); getToolsDescConn = nil end
end

